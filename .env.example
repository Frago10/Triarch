# ─────────────────────────────────────────────────────────
# Triarch — environment variables
# Copia este archivo a .env y llena los valores reales.
# ─────────────────────────────────────────────────────────

# MT5 demo account credentials
# (los obtienes después de abrir cuenta demo — ver docs/setup-mt5-demo.md)
MT5_LOGIN=12345678
MT5_PASSWORD=your_demo_password
MT5_SERVER=ICMarkets-Demo
# Path al terminal.exe de MT5 (opcional — si no se setea, usa el default)
# MT5_PATH=C:\Program Files\MetaTrader 5\terminal64.exe

# ─────────────────────────────────────────────────────────
# Modos de ejecución globales
# ─────────────────────────────────────────────────────────
# DEFAULT_MODE: SIGNAL_ONLY | APPROVAL | AUTO  (los modos por activo se sobreescriben en symbols.yaml)
TRIARCH_DEFAULT_MODE=SIGNAL_ONLY
# Kill switch global. 1 = el bot no emite ninguna señal ni coloca órdenes.
TRIARCH_KILL=0
# Entorno: demo | live  (NUNCA "live" sin haber pasado todos los criterios)
TRIARCH_ENV=demo

# ─────────────────────────────────────────────────────────
# Risk defaults (override en config/symbols.yaml por activo)
# ─────────────────────────────────────────────────────────
RISK_MAX_DAILY_LOSS_PCT=2.0
RISK_MAX_CONSEC_LOSSES=3
RISK_MAX_TRADES_PER_DAY=5
RISK_MIN_RR_RATIO=1.5
RISK_MAX_SLIPPAGE_ATR=1.5

# ─────────────────────────────────────────────────────────
# Confluence layer
# Defaults: min 2 estrategias + 2 familias coincidentes, score combinado ≥ 1.0
# Para debugging (ver señales individuales sin filtro): pon todos en 1 y 0.0
# ─────────────────────────────────────────────────────────
TRIARCH_CONFLUENCE_MIN_SIGNALS=2
TRIARCH_CONFLUENCE_MIN_FAMILIES=2
TRIARCH_CONFLUENCE_MIN_SCORE=1.0

# ─────────────────────────────────────────────────────────
# Notificaciones (opcionales)
# ─────────────────────────────────────────────────────────
# Telegram bot — para signals y aprobaciones
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Discord webhook — alternativa
DISCORD_WEBHOOK_URL=

# ─────────────────────────────────────────────────────────
# Obsidian vault path (donde escribimos postmortems y sessions)
# ─────────────────────────────────────────────────────────
OBSIDIAN_VAULT_PATH=C:\Users\jeanp\Documents\OB vault

# ─────────────────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/triarch.log
